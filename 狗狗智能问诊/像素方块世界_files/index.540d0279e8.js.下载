img {
  border-radius: 8px;
  max-width: 100%;
  height: auto;
}

.image-upload-placeholder {
  border-radius: 8px;
  margin-top: 20px;
  max-width: 100%;
  height: 150px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background-color: rgba(150, 159, 255, 0.2);
}

.node-image {
  margin-top: 20px;
}
.image-wrapper {
  position: relative;
}

.image-helper-box {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 10;
  border: 1px solid #6366F1;
}
.ProseMirror-selectednode.node-image {
  background-color: inherit;
}
.ProseMirror-selectednode.node-image .image-wrapper {
  cursor: zoom-in;
}
