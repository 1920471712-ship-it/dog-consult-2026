  counter-reset: section; /* 创建名为'section'的计数器 */
  overflow-wrap: break-word;
}
h2[data-component="header"] > p {
  line-height: inherit;
}
/** 主题1 */
h2[data-component="header"][data-variant="theme-title-1"] {
  position: relative;
  z-index: 1;
  line-height: 40px;
  padding-left: 56px; /* Increased by 8px from 48px */
  color: var(--coz-mdx-color-7, #309256);
}
h2[data-component="header"][data-variant="theme-title-1"]::before {
  content: "";
  z-index: 2;
  width: 36px;
  padding-left: 6px;
  font-size: 18px;
  position: absolute;
  top: 0;
  bottom: 0;
  left: 8px;
  transform: skewX(-15deg);
  background-color: var(--coz-mdx-color-7, #309256);
}
h2[data-component="header"][data-variant="theme-title-1"]::after {
  content: "";
  z-index: -1;
  position: absolute;
  top: 0;
  bottom: 0;
  left: 48px;
  right: 8px;
  transform: skewX(-15deg);
  background-color: var(--coz-mdx-color-5, #f0faf2);
}
h2[data-component="header"][data-variant="theme-title-1"] > .counter {
  white-space: nowrap;
  align-self: start;
}

h2[data-component="header"][data-variant="theme-title-1"] > .counter::before {
  counter-increment: section;
  content: counter(section, decimal-leading-zero);
  z-index: 2;
  color: #fff;
  margin-right: 20px;
  padding-left: 6px;
  font-size: 18px;
  font-weight: 500;
  position: absolute;
  top: 0;
  bottom: 0;
  left: 8px;
}

/** 主题2 */
h2[data-component="header"][data-variant="theme-title-2"] {
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  color: var(--coz-mdx-color-8);
}
h2[data-component="header"][data-variant="theme-title-2"]::before,
h2[data-component="header"][data-variant="theme-title-2"]::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--coz-stroke-primary);
}
h2[data-component="header"][data-variant="theme-title-2"]::before {
  margin-right: 8px;
}
h2[data-component="header"][data-variant="theme-title-2"]::after {
  margin-left: 8px;
}
`,n=`
div[data-component="highlight"] {
  border-radius: 12px;
  border: 0.5px solid var(--highlight-green-border);
  background: var(--highlight-green-bg);
  padding: 20px;
  margin-top: 20px;
}
div[data-component="highlight"] > *:first-child {
  margin-top: 0;
}
[data-theme="wechat-blue"] div[data-component="highlight"] {
  border-color: var(--highlight-blue-border);
  background: var(--highlight-blue-bg);
}
`,o=`
table {
  width: 100%;
  border-collapse: collapse;
  border-spacing: 0;
  table-layout: fixed;
  text-indent: 0;
  border: 1px solid var(--coz-stroke-primary, rgba(82, 100, 154, 0.13));
  font-size: 13px;
  margin-top: 20px;
  overflow: hidden;
}
table th,
table td {
  position: relative;
  border-top: 1px solid var(--coz-stroke-primary, rgba(82, 100, 154, 0.13));
  border-right: 1px solid var(--coz-stroke-primary, rgba(82, 100, 154, 0.13));
  padding: 8px 16px;
  max-width: 448px;
  text-align: left;
}
table th:last-child,
table td:last-child {
  border-right: none;
}
th.selectedCell,
td.selectedCell {
  background-color: rgba(150, 159, 255, 0.2);
}
table .column-resize-handle {
  background-color: #4538ff;
  pointer-events: none;
  bottom: -2px;
  position: absolute;
  right: -2px;
  top: 0;
  width: 4px;
  z-index: 2;
}
.tiptap table th > p,
.tiptap table td > p {
  margin: 0;
}
.tiptap table th {
  font-weight: 500;
}

.table-view {
  border: 1px solid var(--coz-stroke-primary, rgba(82, 100, 154, 0.13));
  border-radius: 6px;
  margin-top: 20px;
}
.table-view__inner {
  width: 100%;
  overflow-x: auto;
}
.table-view table {
  border: none;
  margin: 0;
}
.table-view table thead th {
  background-color: inherit;
}
.table-view__legend {
  background-color: var(--coz-mg-secondary, rgba(90, 108, 167, .04));
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 16px;
  font-size: 13px;
}
.table-view__legend-button {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  cursor: pointer;
}
.table-view__legend-button svg {
  width: 13px;
  height: 13px;
}
`,l=`
span.node-footnote {
  display: inline-block;
  vertical-align: middle;
  text-align: center;
  line-height: 1;
}
a[data-component="foot-note"] {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 10px;
  font-weight: 500;
  color: var(--coz-fg-primary, rgba(15, 21, 40, 0.82));
  background-color: var(--coz-mg-primary-hovered, rgba(87, 104, 161, 0.08));
  min-width: 16px;
  height: 16px;
  line-height: 16px;
  border-radius: 50%;
  margin-inline: 2px;
  text-decoration: none;
}
`,c=`
div[data-component="echarts"] {
  width: 100%;
  min-width: 600px;
  min-height: 500px;
}
.echarts-wrapper {
  width: 100%;
  overflow-x: auto;
  margin-top: 20px;
}
.ProseMirror-selectednode.node-echarts {
  background-color: inherit;
}
